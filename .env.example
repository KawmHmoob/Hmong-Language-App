# Copy to .env.local (gitignored) and fill in real values.
# Vite exposes only variables prefixed with VITE_ to the client bundle.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe publishable key — safe to ship to the client.
# The secret key and webhook secret live server-side only (never in this file).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
